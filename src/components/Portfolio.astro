---
const projects = [
  { title: "Kopi Senja", category: "Landing Page", slug: "kopi-senja" },
  { title: "Bengkel Mas Yono", category: "Company Profile", slug: "bengkel-mas-yono" },
  { title: "Batik Larasati", category: "Toko Online", slug: "batik-larasati" },
  { title: "Katering Bu Rina", category: "Landing Page", slug: "katering-bu-rina" },
  { title: "Studio Kreatif", category: "Company Profile", slug: "studio-kreatif" },
  { title: "Apotek Sehat", category: "Custom Web App", slug: "apotek-sehat" },
];
---

<section id="portfolio" class="py-20 sm:py-24 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <span class="reveal inline-block text-primary text-sm font-semibold tracking-wider uppercase mb-3">Portfolio</span>
      <h2 class="reveal text-3xl sm:text-4xl font-extrabold tracking-tight">
        Contoh tampilan website
      </h2>
      <p class="reveal text-muted mt-4 max-w-2xl mx-auto text-lg">
        Enam demo untuk melihat arah desain, struktur halaman, dan jenis website yang tersedia. Bukan proyek klien.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((p, i) => (
        <a href={`/portfolio/${p.slug}`} target="_blank" rel="noopener" class="reveal group no-underline" style={`transition-delay: ${(i % 3) * 100}ms`}>
          <div class="relative overflow-hidden rounded-xl border border-gray-200 bg-[#f8f6f0] transition-colors duration-200 group-hover:border-primary">
            <div class="aspect-[16/10] p-6 flex flex-col justify-between border-b border-gray-200">
              <span class="text-xs uppercase tracking-[0.18em] text-muted">Demo 0{i + 1}</span>
              <div>
                <div class="text-2xl font-extrabold text-dark leading-tight">{p.title}</div>
                <div class="mt-3 inline-flex items-center gap-2 text-sm font-semibold text-primary">
                  Buka demo
                  <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                </div>
              </div>
            </div>
            <div class="p-5">
              <span class="text-xs font-medium text-primary bg-primary/10 px-2.5 py-1 rounded-full">{p.category}</span>
              <h3 class="text-base font-bold mt-3 text-dark group-hover:text-primary transition-colors">{p.title}</h3>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
