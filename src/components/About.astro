---
const stats = [
  { value: "50+", label: "Klien Puas" },
  { value: "100+", label: "Proyek Selesai" },
  { value: "4.9", label: "Rating" },
  { value: "24jam", label: "Rata-rata Respon" },
];

const values = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    title: "Cepat & Tepat Waktu",
    desc: "Website selesai dalam hitungan hari, bukan bulan. Kami kerja efisien tanpa mengorbankan kualitas.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: "Harga Terjangkau",
    desc: "Paket mulai Rp 750rb. Harga jelas di depan, tanpa biaya tersembunyi atau tagihan mendadak.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: "Profesional & Terpercaya",
    desc: "Desain modern, performa cepat, dan SEO-ready. Website yang bikin bisnis kamu dipercaya.",
  },
];
---

<section class="py-20 sm:py-24 px-4 bg-light">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <span class="reveal inline-block text-primary text-sm font-semibold tracking-wider uppercase mb-3">Tentang Kami</span>
      <h2 class="reveal text-3xl sm:text-4xl font-extrabold tracking-tight">
        Kenapa pilih <span class="scribble text-primary">Websitetermaju</span>?
      </h2>
      <p class="reveal text-muted mt-4 max-w-2xl mx-auto text-lg">
        Kami paham bahwa pemilik UMKM butuh website yang bagus tanpa harus pusing soal teknis. Serahkan ke kami.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 mb-16">
      {values.map((v) => (
        <div class="reveal bg-white rounded-xl p-8 border border-gray-100 hover:border-primary/20 hover:shadow-lg hover:shadow-primary/5 transition-all duration-300">
          <div class="w-12 h-12 bg-primary/10 text-primary rounded-lg flex items-center justify-center mb-5" set:html={v.icon} />
          <h3 class="text-lg font-bold mb-2">{v.title}</h3>
          <p class="text-muted text-sm leading-relaxed">{v.desc}</p>
        </div>
      ))}
    </div>

    <div class="reveal grid grid-cols-2 md:grid-cols-4 gap-6">
      {stats.map((s) => (
        <div class="text-center py-6 px-4 bg-white rounded-xl border border-gray-100">
          <div class="text-3xl sm:text-4xl font-extrabold text-accent mb-1">{s.value}</div>
          <div class="text-sm text-muted font-medium">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
