---
const testimonials = [
  {
    quote: "Awalnya saya gaptek banget, takut ribet. Ternyata cuma modal chat WA, dua minggu kemudian katering saya sudah punya website sendiri. Pesanan masuk lebih rapi sekarang.",
    name: "Bu Rina",
    role: "Katering Rumahan",
    location: "Yogyakarta",
    initials: "BR",
    color: "bg-emerald-100 text-emerald-700",
    verified: true,
  },
  {
    quote: "Pelanggan baru sering bilang nemu bengkel saya dari Google. Padahal dulu cuma andalkan orang lewat. Worth it banget sih.",
    name: "Mas Dimas",
    role: "Bengkel Motor",
    location: "Semarang",
    initials: "MD",
    color: "bg-blue-100 text-blue-700",
    verified: true,
  },
  {
    quote: "Revisinya sabar banget, saya ganti foto produk berkali-kali nggak pernah diomelin. Hasilnya bagus, teman-teman sesama penjual sampai nanya dibikinin siapa.",
    name: "Mbak Ayu",
    role: "Butik Online",
    location: "Solo",
    initials: "MA",
    color: "bg-rose-100 text-rose-700",
    verified: true,
  },
];
---

<section class="py-20 sm:py-24 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <span class="reveal inline-block text-primary text-sm font-semibold tracking-wider uppercase mb-3">Testimoni</span>
      <h2 class="reveal text-3xl sm:text-4xl font-extrabold tracking-tight">
        Kata mereka yang sudah duluan
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {testimonials.map((t, i) => (
        <div
          class="reveal bg-white rounded-2xl p-8 border border-gray-100 hover:shadow-lg hover:border-gray-200 transition-all duration-200"
          style={`transition-delay: ${i * 100}ms`}
        >
          <!-- Stars -->
          <div class="flex gap-1 mb-5" aria-label="Rating: 5 bintang">
            {[...Array(5)].map(() => (
              <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <blockquote class="text-sm text-muted leading-relaxed mb-6">
            "{t.quote}"
          </blockquote>

          <div class="flex items-center gap-3">
            <!-- Avatar with colored initial -->
            <div class={`w-11 h-11 rounded-full ${t.color} font-bold text-sm flex items-center justify-center flex-shrink-0`} aria-hidden="true">
              {t.initials}
            </div>
            <div class="min-w-0">
              <div class="font-semibold text-sm text-dark flex items-center gap-1.5">
                {t.name}
                {t.verified && (
                  <svg class="w-4 h-4 text-primary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-label="Terverifikasi">
                    <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                )}
              </div>
              <div class="text-xs text-muted">{t.role} · {t.location}</div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom CTA nudge -->
    <p class="reveal text-center text-muted text-sm mt-10">
      Bergabung dengan puluhan pemilik bisnis yang sudah punya website profesional.
      <a href="https://wa.me/628159203331?text=Halo%2C%20saya%20mau%20tanya%20soal%20jasa%20pembuatan%20website." target="_blank" rel="noopener" class="text-primary font-semibold hover:underline ml-1">Mulai sekarang →</a>
    </p>
  </div>
</section>
