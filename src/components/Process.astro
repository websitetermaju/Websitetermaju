---
const steps = [
  {
    num: "01",
    title: "Konsultasi",
    desc: "Ceritakan bisnis dan kebutuhan website kamu lewat WhatsApp. Belum jelas? Kami bantu arahin.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`,
  },
  {
    num: "02",
    title: "Desain & Develop",
    desc: "Dalam 2–5 hari, kamu sudah bisa lihat draf pertama website. Kami kerjakan dengan standar modern.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>`,
  },
  {
    num: "03",
    title: "Revisi",
    desc: "Ada yang kurang pas? Revisi sampai kamu benar-benar puas. Tanpa drama, tanpa biaya tambahan.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>`,
  },
  {
    num: "04",
    title: "Launch!",
    desc: "Website tayang di domain kamu. Kami kasih panduan singkat dan support selama 30 hari.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/></svg>`,
  },
];
---

<section class="py-20 sm:py-24 px-4 bg-light">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <span class="reveal inline-block text-primary text-sm font-semibold tracking-wider uppercase mb-3">Cara Kerja</span>
      <h2 class="reveal text-3xl sm:text-4xl font-extrabold tracking-tight">
        4 langkah mudah
      </h2>
      <p class="reveal text-muted mt-4 max-w-2xl mx-auto text-lg">
        Dari ide sampai website live — prosesnya simpel dan transparan.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {steps.map((step, i) => (
        <div class="reveal relative bg-white rounded-xl p-8 border border-gray-100 text-center group hover:border-primary/20 hover:shadow-lg hover:shadow-primary/5 transition-all duration-300" style={`transition-delay: ${i * 100}ms`}>
          <div class="text-sm font-extrabold text-accent mb-4 tracking-widest">{step.num}</div>
          <div class="w-14 h-14 mx-auto bg-primary/10 text-primary rounded-full flex items-center justify-center mb-5 group-hover:bg-primary group-hover:text-white transition-colors" set:html={step.icon} />
          <h3 class="text-lg font-bold mb-2">{step.title}</h3>
          <p class="text-muted text-sm leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
