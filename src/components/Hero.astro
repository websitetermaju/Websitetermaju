---
const waLink = "https://wa.me/628159203331?text=Halo%2C%20saya%20mau%20tanya%20soal%20jasa%20pembuatan%20website.";
---

<header class="relative pt-28 pb-16 sm:pt-36 sm:pb-20 px-4 overflow-hidden">
  <!-- Dot texture background -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background-image: radial-gradient(circle, #0E7C6620 1.5px, transparent 1.5px); background-size: 32px 32px; opacity: 0.4;"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-4xl mx-auto text-center">

    <!-- Social proof pill -->
    <div class="reveal inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-100 rounded-full shadow-sm mb-8 text-sm">
      <span class="flex gap-0.5" aria-hidden="true">
        {[...Array(5)].map(() => (
          <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        ))}
      </span>
      <span class="font-semibold text-dark">4.9</span>
      <span class="text-muted">· 50+ UMKM sudah punya website</span>
    </div>

    <!-- Headline: specific, not generic -->
    <h1 class="reveal text-4xl sm:text-5xl lg:text-[4.25rem] font-extrabold tracking-tight leading-[1.08] mb-6">
      Cukup chat WA.<br />
      <span class="scribble text-primary">Website<br class="sm:hidden" /> kamu jadi.</span>
    </h1>

    <p class="reveal text-lg sm:text-xl text-muted max-w-2xl mx-auto mb-10 leading-relaxed">
      Dalam 5 hari kerja, bisnis kamu sudah punya website profesional. Kamu cerita lewat WhatsApp — kami yang desain, koding, dan tayangin.
    </p>

    <!-- CTAs -->
    <div class="reveal flex flex-col sm:flex-row items-center justify-center gap-3 mb-12">
      <a
        href={waLink}
        target="_blank"
        rel="noopener"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2.5 px-8 py-4 bg-primary text-white font-semibold rounded-xl hover:bg-primary-dark transition-colors text-base no-underline shadow-lg shadow-primary/25"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2a9.9 9.9 0 0 0-8.5 15.1L2 22l5.1-1.4A10 10 0 1 0 12 2Zm0 18.1c-1.6 0-3.1-.4-4.4-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.1 8.1 0 1 1 12 20.1Zm4.5-6c-.2-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.5.1-.2.2-.6.8-.8 1-.1.2-.3.2-.5.1a6.6 6.6 0 0 1-3.3-2.9c-.2-.4.2-.4.7-1.3 0-.2 0-.3-.1-.4l-.8-1.9c-.2-.5-.4-.4-.5-.4h-.5c-.2 0-.4.1-.7.3-.2.3-.9.9-.9 2.1s.9 2.5 1 2.6c.1.2 1.8 2.7 4.3 3.8.6.3 1.1.4 1.5.6.6.2 1.2.2 1.6.1.5-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.2-1.2l-.4-.3Z"/>
        </svg>
        Chat WA Sekarang
      </a>
      <a
        href="/buat-web-ai"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 border border-gray-200 text-dark font-semibold rounded-xl hover:border-gray-300 hover:bg-white transition-colors text-base no-underline"
      >
        Coba Buat Web AI (Gratis)
        <span class="text-[0.65rem] bg-accent/20 text-accent-dark px-1.5 py-0.5 rounded-full font-bold border border-accent/30 tracking-wider">NEW</span>
      </a>
    </div>

    <!-- SIGNATURE VISUAL: WA → proses → website live -->
    <div class="reveal max-w-3xl mx-auto">
      <div class="bg-white rounded-2xl border border-gray-100 shadow-xl shadow-gray-200/60 p-4 sm:p-8">
        <div class="grid grid-cols-3 gap-2 sm:gap-6 items-center">

          <!-- Kolom 1: WA message -->
          <div class="flex flex-col items-center text-center">
            <div class="flex items-center justify-center w-9 h-9 sm:w-11 sm:h-11 rounded-2xl mb-2 sm:mb-3" style="background-color: #25D36620;">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="#25D366" aria-hidden="true">
                <path d="M12 2a9.9 9.9 0 0 0-8.5 15.1L2 22l5.1-1.4A10 10 0 1 0 12 2Zm0 18.1c-1.6 0-3.1-.4-4.4-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.1 8.1 0 1 1 12 20.1Zm4.5-6c-.2-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.5.1-.2.2-.6.8-.8 1-.1.2-.3.2-.5.1a6.6 6.6 0 0 1-3.3-2.9c-.2-.4.2-.4.7-1.3 0-.2 0-.3-.1-.4l-.8-1.9c-.2-.5-.4-.4-.5-.4h-.5c-.2 0-.4.1-.7.3-.2.3-.9.9-.9 2.1s.9 2.5 1 2.6c.1.2 1.8 2.7 4.3 3.8.6.3 1.1.4 1.5.6.6.2 1.2.2 1.6.1.5-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.2-1.2l-.4-.3Z"/>
              </svg>
            </div>
            <!-- WA bubble (warna asli WhatsApp: #DCF8C6) -->
            <div
              class="rounded-2xl rounded-bl-sm px-2.5 py-2 text-left text-[0.65rem] sm:text-xs text-gray-800 mb-2 sm:mb-3 w-full shadow-sm leading-relaxed"
              style="background-color: #DCF8C6;"
            >
              "Halo, mau tanya soal website buat usaha saya 🙏"
            </div>
            <div class="text-[0.65rem] sm:text-xs font-bold text-dark">Hari ini</div>
            <div class="text-[0.65rem] sm:text-xs text-muted mt-0.5">Kamu kirim pesan</div>
          </div>

          <!-- Kolom 2: Proses (tengah) -->
          <div class="flex flex-col items-center gap-3">
            <div class="flex items-center gap-0.5 sm:gap-1">
              <div class="w-1.5 h-1.5 sm:w-2 sm:h-2 rounded-full bg-primary"></div>
              <div class="w-4 h-px bg-primary/30 sm:w-8"></div>
              <div class="w-1.5 h-1.5 sm:w-2 sm:h-2 rounded-full bg-primary/50"></div>
              <div class="w-4 h-px bg-primary/30 sm:w-8"></div>
              <div class="w-1.5 h-1.5 sm:w-2 sm:h-2 rounded-full bg-primary/20"></div>
            </div>
            <div class="rounded-2xl bg-primary px-4 py-3 text-center shadow-md shadow-primary/20">
              <div class="text-3xl font-extrabold text-white leading-none">5</div>
              <div class="text-xs text-white/80 font-medium mt-0.5">hari kerja</div>
            </div>
            <div class="text-[0.65rem] sm:text-xs text-muted text-center leading-relaxed">
              Kami desain,<br />koding & tayang
            </div>
          </div>

          <!-- Kolom 3: Website live -->
          <div class="flex flex-col items-center text-center">
            <div class="flex items-center justify-center w-9 h-9 sm:w-11 sm:h-11 rounded-2xl bg-primary/10 mb-2 sm:mb-3">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
              </svg>
            </div>
            <!-- URL bar -->
            <div class="w-full bg-gray-50 border border-gray-200 rounded-lg px-2 py-1.5 flex items-center gap-1.5 mb-2 sm:mb-3 shadow-sm">
              <svg class="w-3 h-3 text-primary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-[0.6rem] sm:text-xs text-dark font-medium truncate">kateringburina.com</span>
              <span class="ml-auto flex-shrink-0 w-2 h-2 rounded-full bg-green-400" title="Website aktif" aria-hidden="true"></span>
            </div>
            <div class="text-[0.65rem] sm:text-xs font-bold text-dark">Hari ke-5</div>
            <div class="text-[0.65rem] sm:text-xs text-muted mt-0.5">Website live 🎉</div>
          </div>

        </div>
      </div>
    </div>

    <!-- Trust pills -->
    <div class="reveal mt-8 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-xs text-muted">
      {[
        "Garansi 30 hari uang kembali",
        "Revisi sampai puas",
        "Harga transparan",
        "Balas dalam 1 jam",
      ].map((t) => (
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-primary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          {t}
        </span>
      ))}
    </div>

  </div>
</header>
