---
const waLink = "https://wa.me/628159203331?text=Halo%2C%20saya%20mau%20tanya%20soal%20jasa%20pembuatan%20website.";
---

<header class="pt-28 pb-20 sm:pt-36 sm:pb-28 px-4">
  <div class="max-w-3xl mx-auto text-center">
    <div class="reveal">
      <span class="inline-block px-4 py-1.5 bg-primary/10 text-primary text-xs font-semibold tracking-wider uppercase rounded-full mb-6">
        Jasa Pembuatan Website
      </span>
    </div>

    <h1 class="reveal text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.1] mb-6">
      Website profesional,<br />
      <span class="scribble text-primary">tanpa ribet.</span>
    </h1>

    <p class="reveal text-lg sm:text-xl text-muted max-w-2xl mx-auto mb-10 leading-relaxed">
      Kami bantu UMKM & bisnis punya website modern yang cepat, SEO-friendly, dan bikin pelanggan percaya — kamu tinggal terima jadi.
    </p>

    <div class="reveal flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={waLink}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2.5 px-7 py-3.5 bg-primary text-white font-semibold rounded-lg hover:bg-primary-dark transition-colors text-base no-underline shadow-lg shadow-primary/25"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a9.9 9.9 0 0 0-8.5 15.1L2 22l5.1-1.4A10 10 0 1 0 12 2Zm0 18.1c-1.6 0-3.1-.4-4.4-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.1 8.1 0 1 1 12 20.1Zm4.5-6c-.2-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.5.1-.2.2-.6.8-.8 1-.1.2-.3.2-.5.1a6.6 6.6 0 0 1-3.3-2.9c-.2-.4.2-.4.7-1.3 0-.2 0-.3-.1-.4l-.8-1.9c-.2-.5-.4-.4-.5-.4h-.5c-.2 0-.4.1-.7.3-.2.3-.9.9-.9 2.1s.9 2.5 1 2.6c.1.2 1.8 2.7 4.3 3.8.6.3 1.1.4 1.5.6.6.2 1.2.2 1.6.1.5-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.2-1.2l-.4-.3Z"/></svg>
        Konsultasi Gratis
      </a>
      <a
        href="#portfolio"
        class="inline-flex items-center gap-2 px-7 py-3.5 border border-gray-200 text-dark font-semibold rounded-lg hover:border-gray-300 hover:bg-gray-50 transition-colors text-base no-underline"
      >
        Lihat Portfolio
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </a>
    </div>

    <div class="reveal mt-14 flex items-center justify-center gap-8 sm:gap-12 text-sm text-muted">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
        Balas cepat
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
        Harga transparan
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
        Revisi sampai puas
      </div>
    </div>
  </div>
</header>
