---
import "../../styles/global.css";
import Layout from "../../layouts/Layout.astro";
---

<Layout 
  title="Buat Web AI Gratis untuk UMKM — websitetermaju" 
  description="Generator website bertenaga AI gratis khusus untuk pelaku UMKM dan bisnis kecil Indonesia. Desain profesional, instan, dan siap pakai."
>
  <!-- Builder Header -->
  <header class="bg-slate-900 border-b border-slate-800 text-white py-3 px-4 sm:px-6 flex items-center justify-between sticky top-0 z-40">
    <div class="flex items-center gap-3">
      <a href="/" class="flex items-center gap-1.5 text-base font-extrabold tracking-tight text-white no-underline">
        websitetermaju
        <span class="text-primary-light">✦</span>
      </a>
      <span class="h-4 w-px bg-slate-800 hidden sm:inline"></span>
      <span class="text-xs bg-primary/20 text-primary-light border border-primary/30 px-2.5 py-0.5 rounded-full font-semibold hidden sm:inline-block">
        AI Website Builder untuk UMKM
      </span>
    </div>
    
    <div class="flex items-center gap-3">
      <a href="/" class="text-xs sm:text-sm text-slate-400 hover:text-white transition-colors no-underline flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Kembali ke Beranda
      </a>
    </div>
  </header>

  <!-- Main Workspace -->
  <main class="grid grid-cols-1 lg:grid-cols-12 bg-slate-950 text-slate-100 min-h-[calc(100vh-3.25rem)] overflow-hidden">
    
    <!-- LEFT PANEL: Editor & Controls (Grid: 5 cols) -->
    <section class="lg:col-span-5 border-r border-slate-800 flex flex-col h-[calc(100vh-3.25rem)] overflow-y-auto">
      
      <!-- Tabs Navigation -->
      <div class="flex border-b border-slate-800 sticky top-0 bg-slate-950 z-10">
        <button id="tab-btn-profil" class="flex-1 py-3 text-center text-xs font-semibold border-b-2 border-primary-light text-primary-light transition-all focus:outline-none">
          1. Profil & Niche
        </button>
        <button id="tab-btn-konten" class="flex-1 py-3 text-center text-xs font-semibold border-b-2 border-transparent text-slate-400 hover:text-slate-200 transition-all focus:outline-none">
          2. Isi Konten
        </button>
        <button id="tab-btn-desain" class="flex-1 py-3 text-center text-xs font-semibold border-b-2 border-transparent text-slate-400 hover:text-slate-200 transition-all focus:outline-none">
          3. Desain & Publish
        </button>
      </div>

      <!-- Tab Content Area -->
      <div class="p-5 sm:p-6 space-y-6 flex-1">
        
        <!-- ================= TAB 1: PROFIL & NICHE ================= -->
        <div id="tab-content-profil" class="space-y-5">
          <div>
            <h3 class="text-sm font-bold text-slate-300 mb-1 uppercase tracking-wider">Identitas Usaha</h3>
            <p class="text-xs text-slate-500">Tentukan nama bisnis dan bidang usaha Anda.</p>
          </div>

          <!-- Niche Selection Cards -->
          <div class="space-y-2">
            <label class="block text-xs font-semibold text-slate-300">Pilih Bidang Bisnis (Niche)</label>
            <div class="grid grid-cols-2 gap-2" id="niche-selector">
              <button data-niche="kuliner" class="p-2.5 rounded-lg border border-slate-800 bg-slate-900/50 hover:border-slate-700 text-left text-xs transition-all flex items-center gap-2 select-niche-btn border-primary-light bg-slate-900">
                <span class="text-lg">🍔</span>
                <div>
                  <div class="font-semibold text-slate-200">Kuliner</div>
                  <div class="text-[0.65rem] text-slate-500">Resto, Kafe, Katering</div>
                </div>
              </button>
              <button data-niche="jasa" class="p-2.5 rounded-lg border border-slate-800 bg-slate-900/50 hover:border-slate-700 text-left text-xs transition-all flex items-center gap-2 select-niche-btn">
                <span class="text-lg">🛠️</span>
                <div>
                  <div class="font-semibold text-slate-200">Jasa</div>
                  <div class="text-[0.65rem] text-slate-500">AC, Laundry, Clean</div>
                </div>
              </button>
              <button data-niche="toko" class="p-2.5 rounded-lg border border-slate-800 bg-slate-900/50 hover:border-slate-700 text-left text-xs transition-all flex items-center gap-2 select-niche-btn">
                <span class="text-lg">🛍️</span>
                <div>
                  <div class="font-semibold text-slate-200">Toko Online</div>
                  <div class="text-[0.65rem] text-slate-500">Fashion, Sembako, Kue</div>
                </div>
              </button>
              <button data-niche="salon" class="p-2.5 rounded-lg border border-slate-800 bg-slate-900/50 hover:border-slate-700 text-left text-xs transition-all flex items-center gap-2 select-niche-btn">
                <span class="text-lg">✂️</span>
                <div>
                  <div class="font-semibold text-slate-200">Kecantikan</div>
                  <div class="text-[0.65rem] text-slate-500">Barber, Salon, Spa</div>
                </div>
              </button>
              <button data-niche="kesehatan" class="p-2.5 rounded-lg border border-slate-800 bg-slate-900/50 hover:border-slate-700 text-left text-xs transition-all flex items-center gap-2 select-niche-btn">
                <span class="text-lg">🩺</span>
                <div>
                  <div class="font-semibold text-slate-200">Kesehatan</div>
                  <div class="text-[0.65rem] text-slate-500">Klinik, Apotek, Terapi</div>
                </div>
              </button>
              <button data-niche="bimbel" class="p-2.5 rounded-lg border border-slate-800 bg-slate-900/50 hover:border-slate-700 text-left text-xs transition-all flex items-center gap-2 select-niche-btn">
                <span class="text-lg">✏️</span>
                <div>
                  <div class="font-semibold text-slate-200">Pendidikan</div>
                  <div class="text-[0.65rem] text-slate-500">Les Privat, Bimbel</div>
                </div>
              </button>
            </div>
          </div>

          <!-- Basic Info inputs -->
          <div class="space-y-4">
            <div>
              <label for="input-business-name" class="block text-xs font-semibold text-slate-300 mb-1.5">Nama Bisnis / Toko</label>
              <input type="text" id="input-business-name" class="w-full bg-slate-900 border border-slate-800 rounded-lg px-3.5 py-2 text-sm text-white focus:outline-none focus:border-primary-light" value="Kopi Sedap Malam" placeholder="Contoh: Katering Bu Rina" />
            </div>

            <div>
              <label for="input-whatsapp" class="block text-xs font-semibold text-slate-300 mb-1.5">Nomor WhatsApp Pembeli</label>
              <div class="relative">
                <span class="absolute left-3.5 top-2 text-slate-500 text-sm font-semibold">+62</span>
                <input type="text" id="input-whatsapp" class="w-full bg-slate-900 border border-slate-800 rounded-lg pl-12 pr-3.5 py-2 text-sm text-white focus:outline-none focus:border-primary-light" value="8159203331" placeholder="8123456789" />
              </div>
              <p class="text-[0.65rem] text-slate-500 mt-1">Nomor ini akan dihubungkan ke tombol "Pesan via WhatsApp" di landing page.</p>
            </div>
          </div>

          <!-- AI Generator Section -->
          <div class="border border-slate-800 bg-slate-950 p-4 rounded-xl space-y-4 relative overflow-hidden mt-6">
            <div class="absolute -right-8 -top-8 w-24 h-24 bg-primary/10 rounded-full blur-xl pointer-events-none"></div>
            
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <span class="text-base">✨</span>
                <span class="text-xs font-bold text-slate-200 uppercase tracking-wider">AI Generator Content</span>
              </div>
              <!-- Gemini API Key Toggle -->
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" id="gemini-toggle" class="sr-only peer">
                <div class="w-7 h-4 bg-slate-800 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-slate-400 after:border-gray-300 after:border after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-primary-light peer-checked:after:bg-slate-950"></div>
                <span class="ml-1.5 text-[0.65rem] font-semibold text-slate-400 peer-checked:text-primary-light">Mode Gemini</span>
              </label>
            </div>

            <!-- API Key input (hidden by default) -->
            <div id="gemini-key-container" class="hidden space-y-2 border-t border-slate-900 pt-3">
              <div class="flex items-center justify-between">
                <label for="gemini-api-key" class="block text-[0.7rem] font-semibold text-slate-400">Kunci API Gemini (Gratis)</label>
                <a href="https://aistudio.google.com/" target="_blank" class="text-[0.65rem] text-primary-light hover:underline flex items-center gap-0.5">
                  Dapatkan API Key
                  <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
              </div>
              <input type="password" id="gemini-api-key" class="w-full bg-slate-900 border border-slate-800 rounded-lg px-3 py-1.5 text-xs text-white focus:outline-none focus:border-primary-light placeholder-slate-600" placeholder="AIzaSy..." />
            </div>

            <div>
              <label for="input-description" class="block text-xs font-semibold text-slate-300 mb-1.5">Deskripsikan Usaha Anda</label>
              <textarea id="input-description" rows="3" class="w-full bg-slate-900 border border-slate-800 rounded-lg px-3.5 py-2 text-xs text-white focus:outline-none focus:border-primary-light placeholder-slate-600" placeholder="Contoh: Kedai kopi lokal yang menyajikan biji kopi robusta berkualitas dengan menu andalan kopi susu gula aren dan pisang goreng hangat. Suasana santai cocok untuk mahasiswa nugas."
              >Warung kopi khas Nusantara dengan biji pilihan, suasana nyaman cocok untuk nugas atau sekadar berkumpul.</textarea>
            </div>

            <button id="btn-generate" class="w-full py-2.5 bg-gradient-to-r from-primary to-primary-light text-slate-950 font-bold text-xs rounded-lg hover:brightness-110 transition-all flex items-center justify-center gap-1.5 shadow-md shadow-primary/10">
              <svg class="w-4 h-4 animate-spin hidden" id="generate-spinner" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              <span id="generate-btn-text">Tulis & Susun Pakai AI ✨</span>
            </button>
            <div id="ai-status" class="text-[0.65rem] text-slate-400 text-center italic hidden">Menganalisis jenis bisnis dan merangkai halaman...</div>
          </div>

          <div class="pt-2">
            <button id="next-to-tab2" class="w-full py-3 bg-slate-800 text-white hover:bg-slate-700 font-semibold text-xs rounded-lg transition-colors flex items-center justify-center gap-1">
              Lanjut ke Isi Konten
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
          </div>
        </div>

        <!-- ================= TAB 2: ISI KONTEN ================= -->
        <div id="tab-content-konten" class="space-y-6 hidden">
          <div>
            <h3 class="text-sm font-bold text-slate-300 mb-1 uppercase tracking-wider">Modifikasi Konten</h3>
            <p class="text-xs text-slate-500">Sesuaikan teks detail di bawah untuk menyempurnakan landing page.</p>
          </div>

          <!-- Section: Hero Content -->
          <div class="space-y-3 border-b border-slate-900 pb-5">
            <span class="text-xs font-bold text-primary-light uppercase tracking-wide">1. Bagian Atas (Hero)</span>
            <div>
              <label for="input-slogan" class="block text-[0.7rem] font-semibold text-slate-400 mb-1">Tagline / Slogan</label>
              <input type="text" id="input-slogan" class="w-full bg-slate-900 border border-slate-800 rounded-lg px-3 py-1.5 text-xs text-white focus:outline-none focus:border-primary-light" value="Ngopi Nikmat, Harga Sahabat" />
            </div>
            <div>
              <label for="input-hero-desc" class="block text-[0.7rem] font-semibold text-slate-400 mb-1">Deskripsi Utama</label>
              <textarea id="input-hero-desc" rows="3" class="w-full bg-slate-900 border border-slate-800 rounded-lg px-3 py-1.5 text-xs text-white focus:outline-none focus:border-primary-light"
              >Nikmati seduhan kopi Nusantara otentik dengan suasana cozy. Tempat terbaik untuk bekerja, ngobrol santai, atau melepas penat dengan segelas kopi berkualitas tinggi.</textarea>
            </div>
          </div>

          <!-- Section: Features (Selling Points) -->
          <div class="space-y-4 border-b border-slate-900 pb-5">
            <span class="text-xs font-bold text-primary-light uppercase tracking-wide">2. Keunggulan Kami (Kunci Layanan)</span>
            
            <div id="features-list-container" class="space-y-3">
              <!-- Dynamically populated, template example: -->
              <div class="bg-slate-900/30 border border-slate-900 p-3 rounded-lg space-y-2">
                <span class="text-[0.65rem] font-bold text-slate-500">Keunggulan #1</span>
                <input type="text" id="feature-title-0" class="w-full bg-slate-900 border border-slate-800 rounded px-2.5 py-1 text-xs text-white" value="Biji Kopi Pilihan" />
                <input type="text" id="feature-desc-0" class="w-full bg-slate-900 border border-slate-850 rounded px-2.5 py-1 text-[0.65rem] text-slate-400" value="100% Kopi Robusta & Arabika lokal berkualitas." />
              </div>
              <div class="bg-slate-900/30 border border-slate-900 p-3 rounded-lg space-y-2">
                <span class="text-[0.65rem] font-bold text-slate-500">Keunggulan #2</span>
                <input type="text" id="feature-title-1" class="w-full bg-slate-900 border border-slate-800 rounded px-2.5 py-1 text-xs text-white" value="Tempat Nyaman" />
                <input type="text" id="feature-desc-1" class="w-full bg-slate-900 border border-slate-850 rounded px-2.5 py-1 text-[0.65rem] text-slate-400" value="Dilengkapi WiFi kencang & colokan di setiap meja." />
              </div>
              <div class="bg-slate-900/30 border border-slate-900 p-3 rounded-lg space-y-2">
                <span class="text-[0.65rem] font-bold text-slate-500">Keunggulan #3</span>
                <input type="text" id="feature-title-2" class="w-full bg-slate-900 border border-slate-800 rounded px-2.5 py-1 text-xs text-white" value="Harga Hemat" />
                <input type="text" id="feature-desc-2" class="w-full bg-slate-900 border border-slate-850 rounded px-2.5 py-1 text-[0.65rem] text-slate-400" value="Mulai dari Rp 10.000 saja, pas di kantong mahasiswa." />
              </div>
            </div>
          </div>

          <!-- Section: Services/Products -->
          <div class="space-y-4 border-b border-slate-900 pb-5">
            <span class="text-xs font-bold text-primary-light uppercase tracking-wide">3. Produk / Layanan Utama</span>
            
            <div id="services-list-container" class="space-y-3">
              <!-- Dynamically populated services go here -->
              <div class="bg-slate-900/30 border border-slate-900 p-3 rounded-lg space-y-2">
                <span class="text-[0.65rem] font-bold text-slate-500">Layanan #1</span>
                <div class="flex gap-2">
                  <input type="text" id="service-title-0" class="flex-1 bg-slate-900 border border-slate-800 rounded px-2.5 py-1 text-xs text-white" value="Espresso & Latte" />
                  <input type="text" id="service-price-0" class="w-24 bg-slate-900 border border-slate-800 rounded px-2.5 py-1 text-xs text-primary-light font-bold" value="Rp 12.000" />
                </div>
                <input type="text" id="service-desc-0" class="w-full bg-slate-900 border border-slate-850 rounded px-2.5 py-1 text-[0.65rem] text-slate-400" value="Kopi espresso segar dengan susu gurih." />
              </div>
            </div>
          </div>

          <div class="flex gap-3 pt-2">
            <button id="prev-to-tab1" class="flex-1 py-3 bg-slate-900 border border-slate-800 text-slate-300 hover:text-white font-semibold text-xs rounded-lg transition-colors flex items-center justify-center gap-1">
              <svg class="w-4 h-4 animate-bounce-left" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
              Kembali
            </button>
            <button id="next-to-tab3" class="flex-1 py-3 bg-slate-800 text-white hover:bg-slate-700 font-semibold text-xs rounded-lg transition-colors flex items-center justify-center gap-1">
              Lanjut Desain & Publish
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
          </div>
        </div>

        <!-- ================= TAB 3: DESAIN & PUBLISH ================= -->
        <div id="tab-content-desain" class="space-y-6 hidden">
          <div>
            <h3 class="text-sm font-bold text-slate-300 mb-1 uppercase tracking-wider">Desain & Export</h3>
            <p class="text-xs text-slate-500">Sesuaikan tema warna dan simpan website UMKM Anda.</p>
          </div>

          <!-- Color Palette Picker -->
          <div class="space-y-3 pb-2">
            <label class="block text-xs font-semibold text-slate-300">Pilih Skema Warna</label>
            <div class="grid grid-cols-1 gap-2.5" id="color-theme-picker">
              
              <button data-theme="emerald" class="w-full p-3 rounded-xl border border-slate-800 bg-slate-900/40 text-left hover:border-slate-700 transition-all flex items-center justify-between select-theme-btn border-primary-light">
                <div class="flex items-center gap-2.5">
                  <div class="flex gap-1">
                    <span class="w-4 h-4 rounded-full bg-[#0E7C66]"></span>
                    <span class="w-4 h-4 rounded-full bg-[#F2A93B]"></span>
                    <span class="w-4 h-4 rounded-full bg-[#FBF9F5]"></span>
                  </div>
                  <div>
                    <span class="text-xs font-bold text-slate-200 block">Pasar Pagi (Emerald)</span>
                    <span class="text-[0.65rem] text-slate-500">Gaya sejuk, ramah, dan terpercaya.</span>
                  </div>
                </div>
                <svg class="w-4 h-4 text-primary-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </button>

              <button data-theme="kopisusu" class="w-full p-3 rounded-xl border border-slate-800 bg-slate-900/40 text-left hover:border-slate-700 transition-all flex items-center justify-between select-theme-btn">
                <div class="flex items-center gap-2.5">
                  <div class="flex gap-1">
                    <span class="w-4 h-4 rounded-full bg-[#78350F]"></span>
                    <span class="w-4 h-4 rounded-full bg-[#F59E0B]"></span>
                    <span class="w-4 h-4 rounded-full bg-[#FFFBEB]"></span>
                  </div>
                  <div>
                    <span class="text-xs font-bold text-slate-200 block">Kopi Susu (Warm Coffee)</span>
                    <span class="text-[0.65rem] text-slate-500">Hangat, homey, dan estetik klasik.</span>
                  </div>
                </div>
                <svg class="w-4 h-4 text-primary-light hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </button>

              <button data-theme="ocean" class="w-full p-3 rounded-xl border border-slate-800 bg-slate-900/40 text-left hover:border-slate-700 transition-all flex items-center justify-between select-theme-btn">
                <div class="flex items-center gap-2.5">
                  <div class="flex gap-1">
                    <span class="w-4 h-4 rounded-full bg-[#0284C7]"></span>
                    <span class="w-4 h-4 rounded-full bg-[#F43F5E]"></span>
                    <span class="w-4 h-4 rounded-full bg-[#F0F9FF]"></span>
                  </div>
                  <div>
                    <span class="text-xs font-bold text-slate-200 block">Ocean Blue (Ocean Trust)</span>
                    <span class="text-[0.65rem] text-slate-500">Kepercayaan, profesional, dan segar.</span>
                  </div>
                </div>
                <svg class="w-4 h-4 text-primary-light hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </button>

              <button data-theme="sunset" class="w-full p-3 rounded-xl border border-slate-800 bg-slate-900/40 text-left hover:border-slate-700 transition-all flex items-center justify-between select-theme-btn">
                <div class="flex items-center gap-2.5">
                  <div class="flex gap-1">
                    <span class="w-4 h-4 rounded-full bg-[#EA580C]"></span>
                    <span class="w-4 h-4 rounded-full bg-[#10B981]"></span>
                    <span class="w-4 h-4 rounded-full bg-[#FFF7ED]"></span>
                  </div>
                  <div>
                    <span class="text-xs font-bold text-slate-200 block">Sunset Orange (Energi & Aksi)</span>
                    <span class="text-[0.65rem] text-slate-500">Merangsang aksi, hangat, dan berani.</span>
                  </div>
                </div>
                <svg class="w-4 h-4 text-primary-light hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </button>

              <button data-theme="midnight" class="w-full p-3 rounded-xl border border-slate-800 bg-slate-900/40 text-left hover:border-slate-700 transition-all flex items-center justify-between select-theme-btn">
                <div class="flex items-center gap-2.5">
                  <div class="flex gap-1">
                    <span class="w-4 h-4 rounded-full bg-[#8B5CF6]"></span>
                    <span class="w-4 h-4 rounded-full bg-[#06B6D4]"></span>
                    <span class="w-4 h-4 rounded-full bg-[#0F172A]"></span>
                  </div>
                  <div>
                    <span class="text-xs font-bold text-slate-200 block">Midnight Dark (Modern Tech)</span>
                    <span class="text-[0.65rem] text-slate-500">Premium, berkelas, bernuansa teknologi.</span>
                  </div>
                </div>
