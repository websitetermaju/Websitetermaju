  // AI Content Generator Execution
  generateBtn?.addEventListener("click", async () => {
    const businessName = inputBusName.value.trim();
    const userDescription = inputDescription.value.trim();
    const isGeminiMode = geminiToggle.checked;
    const apiKey = geminiApiKeyInput.value.trim();

    if (!businessName) {
      alert("Masukkan nama bisnis Anda terlebih dahulu.");
      inputBusName.focus();
      return;
    }

    if (!userDescription) {
      alert("Tuliskan deskripsi singkat usaha Anda agar AI memiliki bahan untuk menulis.");
      inputDescription.focus();
      return;
    }

    // Enter Loading State
    generateBtn.setAttribute("disabled", "true");
    generateSpinner?.classList.remove("hidden");
    generateBtnText!.innerText = "AI sedang berpikir...";
    aiStatusText?.classList.remove("hidden");

    try {
      if (isGeminiMode && apiKey) {
        // CALL REAL GEMINI API via client-side fetch
        const prompt = `Anda adalah copywriting expert khusus UMKM Indonesia. Tulis konten website landing page promosi yang sangat menarik dalam Bahasa Indonesia untuk:
        Nama Bisnis: "${businessName}"
        Deskripsi Singkat: "${userDescription}"
        Niche: "${webData.niche}"

        Hasilkan output berupa format JSON murni TANPA markdown block (tanpa \`\`\`json). Harus persis mengikuti skema berikut:
        {
          "slogan": "Tagline marketing yang persuasif dan menangkap perhatian konsumen",
          "description": "Deskripsi hero landing page sepanjang 2-3 kalimat yang mengundang emosi pembaca",
          "features": [
            {"title": "Nama Keunggulan 1 (maks 3 kata)", "desc": "Penjelasan singkat keunggulan 1 (1 kalimat)"},
            {"title": "Nama Keunggulan 2 (maks 3 kata)", "desc": "Penjelasan singkat keunggulan 2 (1 kalimat)"},
            {"title": "Nama Keunggulan 3 (maks 3 kata)", "desc": "Penjelasan singkat keunggulan 3 (1 kalimat)"}
          ],
          "services": [
            {"title": "Produk/Jasa Andalan 1", "price": "Harga / Mulai Rp xx", "desc": "Deskripsi kelebihan produk 1"},
            {"title": "Produk/Jasa Andalan 2", "price": "Harga / Mulai Rp xx", "desc": "Deskripsi kelebihan produk 2"},
            {"title": "Produk/Jasa Andalan 3", "price": "Harga / Mulai Rp xx", "desc": "Deskripsi kelebihan produk 3"}
          ],
          "testimonials": [
            {"name": "Nama Pelanggan 1 (nama lokal indonesia)", "role": "Status (misal: Ibu Rumah Tangga, Karyawan, Pelajar)", "text": "Review kepuasan menggunakan produk ini secara natural"},
            {"name": "Nama Pelanggan 2 (nama lokal indonesia)", "role": "Status", "text": "Review kepuasan secara natural"}
          ]
        }`;

        const endpoint = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${apiKey}`;
        const response = await fetch(endpoint, {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            contents: [{ parts: [{ text: prompt }] }],
            generationConfig: {
              responseMimeType: "application/json"
            }
          })
        });

        if (!response.ok) {
          throw new Error("Gagal terhubung ke API Gemini. Periksa kembali API Key Anda.");
        }

        const resData = await response.json();
        const jsonText = resData.candidates[0].content.parts[0].text;
        const generatedData = JSON.parse(jsonText.replace(/```json/g, '').replace(/```/g, '').trim());

        // Apply generated data to state
        webData.slogan = generatedData.slogan;
        webData.description = generatedData.description;
        webData.features = generatedData.features;
        webData.services = generatedData.services;
        webData.testimonials = generatedData.testimonials;

      } else {
        // FALLBACK / MOCK AI TEMPLATE GENERATOR
        // Simulate thinking time
        await new Promise(resolve => setTimeout(resolve, 1800));

        const baseTmpl = nicheTemplates[webData.niche as keyof typeof nicheTemplates] || nicheTemplates.kuliner;
        
        // Dynamically tailor text values with user inputs
        webData.slogan = `Solusi Terbaik untuk ${businessName}`;
        webData.description = userDescription;
        
        // Inherit default features/services but replace occurrences of business reference if any
        webData.features = JSON.parse(JSON.stringify(baseTmpl.features));
        webData.services = JSON.parse(JSON.stringify(baseTmpl.services));
        webData.testimonials = JSON.parse(JSON.stringify(baseTmpl.testimonials));
      }

      // Update Inputs
      inputSlogan.value = webData.slogan;
      inputHeroDesc.value = webData.description;

      // Update preview and tab UI
      updatePreview();
      renderKontenInputs();
      
      // Auto navigate to Tab 2 to let them review
      showTab("konten");

    } catch (err: any) {
      console.error(err);
      alert(err.message || "Terjadi kesalahan saat memproses generator AI.");
    } finally {
      generateBtn.removeAttribute("disabled");
      generateSpinner?.classList.add("hidden");
      generateBtnText!.innerText = "Tulis & Susun Pakai AI ✨";
      aiStatusText?.classList.add("hidden");
    }
  });

