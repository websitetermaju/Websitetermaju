---
const wa = (msg: string) => `https://wa.me/628159203331?text=${encodeURIComponent(msg)}`;
const products = [
  { name: "Batik Tulis Parang", price: "Rp 450.000", tag: "Tulis", grad: "linear-gradient(135deg,#1B3A5B,#0E2438)" },
  { name: "Batik Cap Mega Mendung", price: "Rp 285.000", tag: "Cap", grad: "linear-gradient(135deg,#7A4419,#4A280E)" },
  { name: "Kemeja Batik Pria", price: "Rp 225.000", tag: "Sarimbit", grad: "linear-gradient(135deg,#1B3A5B,#7A4419)" },
  { name: "Selendang Sutra Sogan", price: "Rp 320.000", tag: "Premium", grad: "linear-gradient(135deg,#9A6B2F,#5C3D17)" },
  { name: "Dress Batik Modern", price: "Rp 375.000", tag: "Modern", grad: "linear-gradient(135deg,#264F73,#142A40)" },
  { name: "Batik Anak Ceria", price: "Rp 145.000", tag: "Anak", grad: "linear-gradient(135deg,#8A5223,#1B3A5B)" },
];
---

<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Batik Larasati — Batik Tulis & Cap Asli</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    :root { --indigo: #1B3A5B; --indigo-dk: #0E2438; --sogan: #8A5223; --gold: #C99A3F; --cream: #F6F1E7; --ink: #1A1A17; }
    body { font-family: 'Jost', sans-serif; color: var(--ink); background: var(--cream); }
    a { text-decoration: none; color: inherit; }
    .serif { font-family: 'Cormorant Garamond', serif; }

    .nav { display: flex; justify-content: space-between; align-items: center; padding: 1.4rem 2rem; max-width: 1150px; margin: 0 auto; }
    .logo { font-family: 'Cormorant Garamond', serif; font-weight: 700; font-size: 1.6rem; letter-spacing: 0.04em; color: var(--indigo); }
    .logo small { display: block; font-family: 'Jost'; font-size: 0.55rem; letter-spacing: 0.35em; text-transform: uppercase; color: var(--sogan); margin-top: -2px; }
    .nav-links { display: flex; gap: 2.2rem; font-size: 0.85rem; letter-spacing: 0.05em; }
    .nav-links a:hover { color: var(--sogan); }
    .nav-cta { border: 1px solid var(--indigo); color: var(--indigo); padding: 0.6rem 1.3rem; border-radius: 2px; font-size: 0.8rem; letter-spacing: 0.05em; transition: all .25s; }
    .nav-cta:hover { background: var(--indigo); color: var(--cream); }

    .hero { position: relative; background: var(--indigo-dk); color: var(--cream); overflow: hidden; }
    .hero::before { content: ""; position: absolute; inset: 0; background-image: radial-gradient(circle at 1px 1px, rgba(201,154,63,0.25) 1px, transparent 0); background-size: 22px 22px; opacity: 0.4; }
    .hero-inner { position: relative; max-width: 1150px; margin: 0 auto; padding: 6rem 2rem 7rem; text-align: center; }
    .eyebrow { font-size: 0.7rem; letter-spacing: 0.4em; text-transform: uppercase; color: var(--gold); margin-bottom: 1.5rem; }
    .hero h1 { font-family: 'Cormorant Garamond', serif; font-weight: 600; font-size: clamp(2.6rem, 6vw, 4.6rem); line-height: 1.05; margin-bottom: 1.4rem; }
    .hero h1 em { color: var(--gold); font-style: italic; }
    .hero p { max-width: 520px; margin: 0 auto 2.4rem; opacity: 0.8; font-weight: 300; line-height: 1.8; }
    .btn-gold { display: inline-flex; align-items: center; gap: 0.6rem; background: var(--gold); color: var(--indigo-dk); padding: 0.95rem 2.2rem; border-radius: 2px; font-weight: 600; letter-spacing: 0.03em; transition: transform .2s; }
    .btn-gold:hover { transform: translateY(-2px); }

    .strip { background: var(--sogan); color: var(--cream); text-align: center; padding: 0.8rem; font-size: 0.8rem; letter-spacing: 0.15em; text-transform: uppercase; }

    .shop { max-width: 1150px; margin: 0 auto; padding: 5rem 2rem; }
    .shop-head { text-align: center; margin-bottom: 3.5rem; }
    .shop-head h2 { font-family: 'Cormorant Garamond', serif; font-size: 2.6rem; font-weight: 600; color: var(--indigo); }
    .shop-head .rule { width: 60px; height: 2px; background: var(--gold); margin: 1rem auto 0; }
    .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.8rem; }
    .card { background: #fff; border: 1px solid #E6DCC9; border-radius: 3px; overflow: hidden; transition: box-shadow .3s, transform .3s; }
    .card:hover { box-shadow: 0 16px 40px rgba(27,58,91,0.12); transform: translateY(-4px); }
    .card-img { position: relative; aspect-ratio: 3/4; display: flex; align-items: flex-end; padding: 1rem; }
    .card-tag { position: absolute; top: 1rem; left: 1rem; background: rgba(246,241,231,0.92); color: var(--indigo); font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.3rem 0.7rem; border-radius: 2px; }
    .motif { position: absolute; inset: 0; opacity: 0.18; background-image: repeating-linear-gradient(45deg, #fff 0 6px, transparent 6px 14px); }
    .card-body { padding: 1.3rem 1.4rem 1.5rem; }
    .card-body h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 600; margin-bottom: 0.3rem; }
    .card-price { color: var(--sogan); font-weight: 600; margin-bottom: 1rem; }
    .card-btn { display: block; text-align: center; border: 1px solid var(--indigo); color: var(--indigo); padding: 0.6rem; border-radius: 2px; font-size: 0.82rem; letter-spacing: 0.04em; transition: all .25s; }
    .card-btn:hover { background: var(--indigo); color: var(--cream); }

    .story { background: #fff; }
    .story-inner { max-width: 1150px; margin: 0 auto; padding: 5rem 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
    .story-img { aspect-ratio: 4/5; background: linear-gradient(160deg, var(--indigo), var(--sogan)); border-radius: 4px; position: relative; overflow: hidden; }
    .story-img::after { content: ""; position: absolute; inset: 0; background-image: repeating-linear-gradient(45deg, rgba(201,154,63,0.25) 0 8px, transparent 8px 20px); }
    .story h2 { font-family: 'Cormorant Garamond', serif; font-size: 2.4rem; font-weight: 600; color: var(--indigo); margin-bottom: 1.2rem; line-height: 1.15; }
    .story p { color: #5A5347; line-height: 1.9; margin-bottom: 1.2rem; font-weight: 300; }
    .story .sign { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.3rem; color: var(--sogan); }

    .cta { background: var(--indigo-dk); color: var(--cream); text-align: center; padding: 5rem 2rem; position: relative; overflow: hidden; }
    .cta::before { content: ""; position: absolute; inset: 0; background-image: radial-gradient(circle at 1px 1px, rgba(201,154,63,0.2) 1px, transparent 0); background-size: 22px 22px; opacity: 0.4; }
    .cta-inner { position: relative; }
    .cta h2 { font-family: 'Cormorant Garamond', serif; font-size: 2.6rem; font-weight: 600; margin-bottom: 0.8rem; }
    .cta p { opacity: 0.75; margin-bottom: 2rem; font-weight: 300; }

    footer { background: #000; color: rgba(246,241,231,0.55); text-align: center; padding: 2.2rem; font-size: 0.82rem; }
    footer a { color: var(--gold); }

    @media (max-width: 820px) {
      .nav-links { display: none; }
      .grid { grid-template-columns: 1fr 1fr; gap: 1rem; }
      .story-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    }
    @media (max-width: 480px) { .grid { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <div class="strip">Gratis Ongkir Pulau Jawa &middot; Pembayaran Aman via WhatsApp</div>
  <nav class="nav">
    <div class="logo">Larasati<small>Batik Nusantara</small></div>
    <div class="nav-links">
      <a href="#koleksi">Koleksi</a>
      <a href="#cerita">Cerita Kami</a>
      <a href="#kontak">Kontak</a>
    </div>
    <a href={wa("Halo Larasati, saya mau tanya koleksi batik.")} class="nav-cta" target="_blank">Pesan via WA</a>
  </nav>

  <section class="hero">
    <div class="hero-inner">
      <div class="eyebrow">Batik Tulis &amp; Cap Asli</div>
      <h1>Warisan kain,<br /><em>dikenakan masa kini.</em></h1>
      <p>Setiap helai dibatik tangan oleh perajin Pekalongan. Motif klasik, jahitan rapi, harga jujur langsung dari pengrajin.</p>
      <a href="#koleksi" class="btn-gold">Lihat Koleksi</a>
    </div>
  </section>

  <section class="shop" id="koleksi">
    <div class="shop-head">
      <h2 class="serif">Koleksi Pilihan</h2>
      <div class="rule"></div>
    </div>
    <div class="grid">
      {products.map((p) => (
        <div class="card">
          <div class="card-img" style={`background:${p.grad}`}>
            <div class="motif"></div>
            <span class="card-tag">{p.tag}</span>
          </div>
          <div class="card-body">
            <h3>{p.name}</h3>
            <div class="card-price">{p.price}</div>
            <a href={wa(`Halo Larasati, saya mau pesan ${p.name} (${p.price}).`)} class="card-btn" target="_blank">Pesan via WhatsApp</a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="story" id="cerita">
    <div class="story-inner">
      <div class="story-img"></div>
      <div>
        <h2>Dari tangan perajin,<br />untuk lemari kamu.</h2>
        <p>Larasati lahir dari kampung batik di Pekalongan. Kami bekerja langsung dengan 12 perajin keluarga — tanpa perantara, tanpa pabrik besar.</p>
        <p>Itu sebabnya tiap kain punya cerita: canting yang sama, tangan yang sama, sejak tiga generasi.</p>
        <div class="sign">— Ibu Larasati, pendiri</div>
      </div>
    </div>
  </section>

  <section class="cta" id="kontak">
    <div class="cta-inner">
      <h2 class="serif">Mau lihat motif lainnya?</h2>
      <p>Chat kami, kirim foto koleksi terbaru langsung ke WhatsApp kamu.</p>
      <a href={wa("Halo Larasati, boleh minta katalog batik terbaru?")} class="btn-gold" target="_blank">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a9.9 9.9 0 0 0-8.5 15.1L2 22l5.1-1.4A10 10 0 1 0 12 2Z"/></svg>
        Minta Katalog
      </a>
    </div>
  </section>

  <footer>
    <p>&copy; 2026 Batik Larasati. Dibuat oleh <a href="https://webtermajuumkm.com">Websitetermaju</a></p>
  </footer>
</body>
</html>
